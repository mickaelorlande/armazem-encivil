#!/bin/sh
# ENCIVIL — pre-commit hook (versionado; aplicado por core.hooksPath=.githooks)
#
#   1) Bloqueia commits com secrets em ficheiros staged.
#   2) Corre o type-check (npm run typecheck) e bloqueia se houver erros.
#
# Para ignorar pontualmente (usar com cuidado): git commit --no-verify

ALLOWLIST_PATTERNS="sb_publishable_"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

SECRET_PATTERNS="sb_secret_|service_role|SUPABASE_SERVICE_ROLE|sk-[a-zA-Z0-9]{32,}|eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[a-zA-Z0-9_-]{100,}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# ── 1. Scan de secrets ──────────────────────────────────────────
if [ -n "$STAGED_FILES" ]; then
  FOUND=0
  for FILE in $STAGED_FILES; do
    case "$FILE" in
      *.png|*.jpg|*.jpeg|*.ico|*.woff|*.woff2|package-lock.json|pnpm-lock.yaml|yarn.lock)
        continue
        ;;
      .githooks/*)
        # Os próprios hooks contêm os padrões de deteção (definição), não secrets.
        continue
        ;;
    esac
    MATCHES=$(git show ":$FILE" 2>/dev/null | grep -nE "$SECRET_PATTERNS" | grep -v "$ALLOWLIST_PATTERNS")
    if [ -n "$MATCHES" ]; then
      echo ""
      echo "${RED}ERRO: Possível secret detetado em: $FILE${NC}"
      echo "$MATCHES" | head -5
      FOUND=1
    fi
  done

  if [ "$FOUND" -eq 1 ]; then
    echo ""
    echo "${YELLOW}Commit bloqueado. Remove os secrets antes de commitar.${NC}"
    echo "Para ignorar (usar com cuidado): git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# ── 2. Type-check ───────────────────────────────────────────────
# Só corre se o npm estiver disponível e houver dependências instaladas.
if command -v npm >/dev/null 2>&1 && [ -d node_modules ]; then
  echo "${YELLOW}A verificar tipos (npm run typecheck)…${NC}"
  if ! npm run typecheck --silent; then
    echo ""
    echo "${RED}Commit bloqueado: há erros de TypeScript.${NC}"
    echo "${YELLOW}Corrige-os (ou, com cuidado: git commit --no-verify).${NC}"
    echo ""
    exit 1
  fi
  echo "${GREEN}Tipos OK.${NC}"
fi

exit 0
